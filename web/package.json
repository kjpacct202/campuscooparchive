{
  "name": "campus-coop-archive",
  "version": "0.1.0",
  "private": true,
  "description": "Campus COOP Archive — public website (continuity sibling of Campus Alert Archive and the Higher Ed EOP Atlas)",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "predev": "node scripts/prepare-data.mjs && node scripts/build-downloads.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/prepare-data.mjs && node scripts/build-downloads.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cmdk": "1.0.4",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.35",
    "typescript": "5.5.3"
  }
}
